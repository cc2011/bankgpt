# ── Hatchet connection ────────────────────────────────────────────────────────
# The SDK (Hatchet() in worker.py / main.py) reads these env vars directly,
# so switching between Cloud and local is config-only — no code changes.

# Tenant-scoped API token.
#   • Hatchet Cloud: copy from https://cloud.onhatchet.run → Settings → API Tokens
#   • Local self-hosted: open http://localhost:8888 (admin@example.com / Admin123!!),
#     create a tenant, then Settings → API Tokens → generate. Paste it here.
HATCHET_CLIENT_TOKEN=""

# Required ONLY for local self-hosted Hatchet started without TLS
# (e.g. via `hatchet server start` or docker-compose.hatchet.yml).
# Leave unset / remove this line when using Hatchet Cloud.
HATCHET_CLIENT_TLS_STRATEGY=none
